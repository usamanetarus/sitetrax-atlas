# ── Gemini via Vertex AI + ADC ───────────────────────────────
# Auth uses Application Default Credentials — run once:
#   gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Gemini model ─────────────────────────────────────────────
GOOGLE_MODEL=gemini-2.5-flash

# ── Data source ──────────────────────────────────────────────
# Set to "true" to use the real SiteTrax REST API instead of mock data
USE_REAL_API=false

# ── Persistence (Firestore, uses ADC) ───────────────────────
# Set to "true" for durable Cloud Run-safe persistence of chat sessions,
# monitoring rules, and opportunities. Startup fails if Firestore is unavailable.
# On Cloud Run this defaults to true when USE_FIRESTORE is omitted.
USE_FIRESTORE=false

# ── Alerts: email + automatic evaluation ────────────────────
# EMAIL_PROVIDER: none (log only) | resend
EMAIL_PROVIDER=none
RESEND_API_KEY=
ALERT_EMAIL_FROM=onboarding@resend.dev
ALERT_EMAIL_TO=
# Background poller (local only; on Cloud Run use Cloud Scheduler -> /tasks/evaluate)
ENABLE_POLLER=false
EVAL_INTERVAL_SECONDS=300
# Shared secret required on /tasks/evaluate when set
TASKS_TOKEN=

# ── SiteTrax API (only needed when USE_REAL_API=true) ────────
SITETRAX_API_BASE=https://api.sitetrax.io
SITETRAX_ACCESS_TOKEN=your-jwt-access-token-here
SITETRAX_REFRESH_TOKEN=your-jwt-refresh-token-here
# Refresh the access token this many seconds before JWT expiration.
SITETRAX_REFRESH_SKEW_SECONDS=60
# Some historical/facility-scoped endpoints are slow for older yards.
SITETRAX_FACILITY_TIMEOUT=90

# ── Remote MCP server (Anthropic connector / claude.ai) ─────
# MCP_SERVER_URL: public HTTPS URL where mcp_http_server is deployed
#   e.g. https://sitetrax-mcp-abc123-uc.a.run.app
# MCP_CLIENT_SECRET: passkey users enter in the OAuth login form to get tokens.
#   Generate with: openssl rand -base64 32
MCP_SERVER_URL=
MCP_CLIENT_SECRET=
MCP_TOKEN_TTL=3600

# ── Server ───────────────────────────────────────────────────
PORT=8000
# CORS: comma-separated origins or "*" for all (default). Set to your frontend URL on Cloud Run.
# e.g. ALLOW_ORIGINS=https://your-frontend.run.app,https://your-custom-domain.com
ALLOW_ORIGINS=*
